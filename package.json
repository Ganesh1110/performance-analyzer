{
  "name": "react-native-performance-analyzer",
  "version": "2.0.0",
  "description": "Comprehensive React Native performance analysis tool",
  "main": "index.js",
  "scripts": {
    "analyze": "node index.js",
    "analyze:full": "node index.js --enforce-budgets --update-baseline",
    "compare": "node index.js --compare",
    "check-budgets": "node index.js --enforce-budgets",
    "test": "jest",
    "serve": "node -e \"require('http').createServer((req,res)=>{res.writeHead(200,{'Content-Type':'text/html'});res.end(require('fs').readFileSync('performance_report.html'));}).listen(3000);console.log('Report available at http://localhost:3000');\""
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/plugin-syntax-jsx": "^7.29.7",
    "@babel/plugin-syntax-typescript": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "jest": "^30.4.2"
  }
}
